# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Microsoft Azure AD App
# Register a PUBLIC client app at https://portal.azure.com
# Supported account types: Personal Microsoft accounts only (consumers)
# Delegated permission required: Tasks.ReadWrite
# Redirect URI in Azure must be: https://<ngrok-url>/auth/callback
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret

# OAuth2 Redirect URI
# IMPORTANT: path must be exactly /auth/callback (nothing after it)
# Example: https://2539-92-81-159-158.ngrok-free.app/auth/callback
OAUTH_REDIRECT_URI=https://xxxx-xx-xx-xx-xx.ngrok-free.app/auth/callback

# Microsoft To Do - Target list ID
# Run 'npm run auth' once to authenticate and see your list IDs
TODO_LIST_ID=your_todo_list_id

# Optional
TIMEZONE=Europe/Bucharest
TOKEN_STORE_PATH=./.tokens.json

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Microsoft Azure AD App Configuration
# 
# In Azure Portal -> Your App -> Authentication:
#   Platform type: 'Mobile and desktop applications' (NOT Web)
#   Redirect URI: http://localhost:3000/auth/callback
#   (Public clients don't need a client secret)
# 
# In Azure Portal -> Your App -> API Permissions:
#   Add 'Microsoft Graph' -> 'Delegated permissions' -> 'Tasks.ReadWrite'
#
AZURE_CLIENT_ID=your_azure_client_id

# AZURE_CLIENT_SECRET is optional - only needed if using 'Web' platform
# For 'Mobile and desktop applications' platform, leave this commented out:
# AZURE_CLIENT_SECRET=your_secret_here

# OAuth2 Redirect URI - use localhost directly (no ngrok needed!)
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# Microsoft To Do - Target list ID
# Run 'npm run auth' once to authenticate and see your list IDs
TODO_LIST_ID=your_todo_list_id

# Optional
TIMEZONE=Europe/Bucharest
TOKEN_STORE_PATH=./.tokens.json

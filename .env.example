# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Microsoft Azure AD App
# Register as a PUBLIC CLIENT app (no secret needed)
# Supported account types: Personal Microsoft accounts (consumers)
# Add delegated permission: Tasks.ReadWrite
# Enable 'Allow public client flows' in Authentication settings
AZURE_CLIENT_ID=your_azure_client_id

# Microsoft To Do - Target list ID
# Run 'npm run lists' or check via /lists command after first auth
TODO_LIST_ID=your_todo_list_id

# Optional
TIMEZONE=Europe/Bucharest
